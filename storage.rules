rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email in ['ksy535760@gmail.com'];
    }

    match /contact-attachments/{userId}/{fileName} {
      allow read, write: if signedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
  }
}
