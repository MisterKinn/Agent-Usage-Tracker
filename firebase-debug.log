[debug] [2026-07-08T14:46:34.820Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/agent-usage-tracker/rulesets {"name":"projects/agent-usage-tracker/rulesets/ceef39f1-92ac-4ff6-b5c5-b9c5479cdfbc","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return signedIn()\n        && request.auth.token.email is string\n        && request.auth.token.email in ['ksy535760@gmail.com', 'seong@yeon.work'];\n    }\n\n    function writesOwnAuthUid() {\n      return signedIn()\n        && request.resource.data.authUid is string\n        && request.resource.data.authUid == request.auth.uid;\n    }\n\n    function ownsAuthUid(resourceData) {\n      return signedIn()\n        && resourceData.authUid is string\n        && resourceData.authUid == request.auth.uid;\n    }\n\n    match /usageEvents/{eventId} {\n      allow read: if signedIn();\n      allow create, update: if false;\n      allow delete: if isAdmin();\n    }\n\n    match /usageDailySummaries/{summaryId} {\n      allow read: if signedIn();\n      allow create, update: if false;\n      allow delete: if isAdmin();\n    }\n\n    match /trackerClients/{clientId} {\n      allow read: if signedIn();\n      allow create, update: if false;\n      allow delete: if isAdmin();\n    }\n\n    match /contactMessages/{messageId} {\n      allow create: if writesOwnAuthUid();\n      allow read: if isAdmin() || ownsAuthUid(resource.data);\n      allow update, delete: if isAdmin();\n    }\n\n    match /visitorInsights/{insightId} {\n      allow read: if isAdmin() || ownsAuthUid(resource.data);\n      allow create, update: if writesOwnAuthUid();\n      allow delete: if isAdmin();\n    }\n\n    match /userProfiles/{profileId} {\n      allow read: if isAdmin() || (signedIn() && profileId == request.auth.uid);\n      allow create, update: if writesOwnAuthUid() && profileId == request.auth.uid;\n      allow delete: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-07-08T14:46:34.723103Z","metadata":{"services":["cloud.firestore"]}}
