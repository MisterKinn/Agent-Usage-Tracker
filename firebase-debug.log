[debug] [2026-07-08T07:57:37.410Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/agent-usage-tracker/rulesets {"name":"projects/agent-usage-tracker/rulesets/c46ab70b-0c30-411d-b82b-3d140167f06c","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function writesOwnAuthUid() {\n      return signedIn()\n        && request.resource.data.authUid is string\n        && request.resource.data.authUid == request.auth.uid;\n    }\n\n    match /usageEvents/{eventId} {\n      allow read: if signedIn();\n      allow create, update: if writesOwnAuthUid();\n    }\n\n    match /trackerClients/{clientId} {\n      allow read: if signedIn();\n      allow create, update: if signedIn() && clientId == request.auth.uid;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-07-08T07:57:37.300623Z","metadata":{"services":["cloud.firestore"]}}
